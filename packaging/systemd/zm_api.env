# ZM API Configuration
APP_PROFILE=prod
APP_CONFIG_DIR=/etc/zm_api
APP_STATIC_DIR=/usr/share/zm_api/static
APP_LOG_DIR=/var/log/zm_api
RUST_LOG=info

# Daemon controller settings
#
# ENABLED=false is "passive" mode: zm_api serves the REST API only and leaves
# ZoneMinder's own daemons (zmdc.pl/zmc/zmfilter/...) alone, so it is safe to
# install alongside a running ZoneMinder. To have zm_api take over daemon
# supervision, disable zoneminder.service, set this to true and restart zm_api
# — or just run: sudo zm_api-takeover
APP_DAEMON__ENABLED=false
APP_DAEMON__SOCKET_PATH=/run/zm
APP_DAEMON__SOCKET_NAME=zmdc.sock
APP_DAEMON__BIN_PATH=/usr/bin
APP_DAEMON__SCRIPT_PATH=/usr/share/zoneminder/scripts
APP_DAEMON__ENABLE_SOCKET_IPC=true
APP_DAEMON__ENABLE_WATCHDOG=true

# JWT signing keys. Packaged installs keep these in the service StateDirectory
# (/var/lib/zm_api/keys), not under /usr/share — they are mutable secrets and
# are generated on first install by the package's post-install script.
APP_SECRET__PRIVATE_ACCESS_KEY=/var/lib/zm_api/keys/private_access_rsa_key.pem
APP_SECRET__PUBLIC_ACCESS_KEY=/var/lib/zm_api/keys/public_access_rsa_key.pem
APP_SECRET__PRIVATE_REFRESH_KEY=/var/lib/zm_api/keys/private_refresh_rsa_key.pem
APP_SECRET__PUBLIC_REFRESH_KEY=/var/lib/zm_api/keys/public_refresh_rsa_key.pem

# TLS settings (uncomment and configure as needed)
# APP_SERVER__TLS__ENABLED=true
# APP_SERVER__TLS__CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
# APP_SERVER__TLS__KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

# ACME/Let's Encrypt settings (uncomment and configure as needed)
# APP_SERVER__ACME__ENABLED=true
# APP_SERVER__ACME__DOMAINS__0=api.example.com
# APP_SERVER__ACME__CONTACT_EMAILS__0=ops@example.com
# APP_SERVER__ACME__CACHE_DIR=/var/lib/zm_api/acme
# APP_SERVER__ACME__PRODUCTION=true
# APP_SERVER__ACME__CHALLENGE=tls-alpn-01
# APP_SERVER__ACME__HTTP_PORT=80
